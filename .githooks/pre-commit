#!/usr/bin/env bash
# Repo-tracked Git pre-commit hook — block direct commits to main/master.
# Catches edits coming through any tool (Cursor, vim, plain `git commit`, etc.)
# that the Claude Code hook cannot see.
#
# Bypass for the rare hotfix case: standard Git escape hatch on commit.
# Auto-installed via `npm install` (see package.json `scripts.prepare`).

set -euo pipefail

# GitHub Actions の edu-watch-bot による自動収集 commit は通す。
# `.github/workflows/fetch-news.yml` がボットの user.email を
# `notify@edu-evidence.org` に設定しており、`GITHUB_ACTIONS=true` は
# Actions ランナーがセットする環境変数(ローカルでは未設定)。
# 両方の条件を要求することで、ローカルで誰かが手動で user.email を
# 偽装して main 直接コミットすることを防ぐ。
if [ "${GITHUB_ACTIONS:-}" = "true" ] && \
   [ "$(git config user.email 2>/dev/null)" = "notify@edu-evidence.org" ]; then
  exit 0
fi

branch=$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo "")

case "$branch" in
  main|master)
    {
      echo "[pre-commit] BLOCKED: direct commit on '$branch' is forbidden."
      echo "[pre-commit] Move the change to a feature branch:"
      echo "    git stash"
      echo "    git checkout -b <type>/<short-description>"
      echo "    git stash pop"
      echo "    git commit ..."
      echo "[pre-commit] Server-side branch protection on GitHub catches the rest."
    } >&2
    exit 1
    ;;
esac

exit 0
