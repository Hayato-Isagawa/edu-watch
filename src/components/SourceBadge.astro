---
import { getSourceMeta } from "../lib/source-meta.ts";
interface Props {
  sourceId: string;
  sourceName: string;
  linkable?: boolean;
}
const { sourceId, sourceName, linkable = true } = Astro.props;
const meta = getSourceMeta(sourceId);
const color = meta?.badgeColor ?? "#3a3a3a";
const label = meta?.shortName ?? sourceName;
const className =
  "inline-flex items-center px-2 py-0.5 text-[11px] font-medium tracking-wide text-white rounded-sm whitespace-nowrap hover:opacity-90 transition-opacity";
---

{
  linkable ? (
    <a
      href={`/sources/${sourceId}/`}
      class={className}
      style={`background-color: ${color}`}
      data-source={sourceId}
    >
      {label}
    </a>
  ) : (
    <span class={className} style={`background-color: ${color}`} data-source={sourceId}>
      {label}
    </span>
  )
}
