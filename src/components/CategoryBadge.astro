---
interface Props {
  category: string;
}
const { category } = Astro.props;
---

<span
  class="inline-flex items-center px-2 py-0.5 text-[11px] font-medium tracking-wide text-[var(--color-sub)] border border-[var(--color-line)] rounded-sm whitespace-nowrap bg-[var(--color-card)]"
>
  {category}
</span>
