---
import SourceBadge from "./SourceBadge.astro";
import { SOURCE_META } from "../lib/source-meta.ts";

const tier1 = Object.values(SOURCE_META).filter((s) => s.layer === 1);
const tier2 = Object.values(SOURCE_META).filter((s) => s.layer === 2);

const categories = [
  "いじめ",
  "不登校",
  "ICT / GIGA",
  "政策・制度",
  "研究・エビデンス",
  "国際・海外",
  "教員・働き方",
  "その他",
];
---

<section
  aria-labelledby="sources-intro-heading"
  class="mt-8 sm:mt-10 p-5 sm:p-6 border border-[var(--color-line)] bg-[var(--color-card)] rounded-sm"
>
  <h2
    id="sources-intro-heading"
    class="font-mono text-[10px] uppercase tracking-widest text-[var(--color-ink)]"
  >
    Data sources / 掲載媒体について
  </h2>

  <p class="mt-3 text-sm leading-relaxed text-[var(--color-sub)]">
    edu-watch は教育の一次情報と専門紙の教育記事を日次で自動収集します。
    タイトルは原文のまま、公式 URL に直接リンクし、日次記事に編集者の意見は加えません
    (論点整理は週次ダイジェストで提供します)。
  </p>

  <div class="mt-5 grid sm:grid-cols-2 gap-5">
    <div>
      <div class="text-xs font-bold text-[var(--color-ink)]">
        Tier 1 — 一次情報
      </div>
      <p class="mt-1 text-xs leading-relaxed text-[var(--color-sub)]">
        政府機関・研究所の発信。報告書・調査結果・政策発表など。
      </p>
      <div class="mt-2 flex flex-wrap gap-1.5">
        {tier1.map((s) => (
          <SourceBadge sourceId={s.sourceId} sourceName={s.displayName} />
        ))}
      </div>
      <ul class="mt-2 text-[11px] leading-relaxed text-[var(--color-sub)] space-y-0.5">
        {tier1.map((s) => (
          <li>
            <span class="font-bold text-[var(--color-ink)]">{s.shortName}</span>
            <span class="ml-1">— {s.displayName}</span>
          </li>
        ))}
      </ul>
    </div>

    <div>
      <div class="text-xs font-bold text-[var(--color-ink)]">
        Tier 2 — 教育専門紙・通信社
      </div>
      <p class="mt-1 text-xs leading-relaxed text-[var(--color-sub)]">
        教育専門紙・大手通信社の教育関連記事。引用範囲遵守(タイトル原文・要約のみ)。
      </p>
      <div class="mt-2 flex flex-wrap gap-1.5">
        {tier2.map((s) => (
          <SourceBadge sourceId={s.sourceId} sourceName={s.displayName} />
        ))}
      </div>
      <ul class="mt-2 text-[11px] leading-relaxed text-[var(--color-sub)] space-y-0.5">
        {tier2.map((s) => (
          <li>
            <span class="font-bold text-[var(--color-ink)]">{s.shortName}</span>
            <span class="ml-1">— {s.displayName}</span>
          </li>
        ))}
      </ul>
      <p class="mt-3 text-[11px] leading-relaxed text-[var(--color-sub)]">
        日本教育新聞の一部記事は媒体サイトでの会員登録(無料 or 有料)が必要です。
        該当記事には <span
          class="inline-flex items-center px-1.5 py-0.5 text-[10px] font-medium text-[#7a4a00] bg-[#fbe6c2] border border-[#e9c98a] rounded-sm align-middle"
        >会員限定</span> バッジを付けて事前に予告します。
      </p>
    </div>
  </div>

  <div class="mt-5 pt-4 border-t border-[var(--color-line)]">
    <div class="text-xs font-bold text-[var(--color-ink)]">カテゴリ</div>
    <p class="mt-1 text-[11px] leading-relaxed text-[var(--color-sub)]">
      タイトル・要約のキーワードに基づき、各記事に最大 3 つ自動付与します。
    </p>
    <div class="mt-2 flex flex-wrap gap-1.5">
      {categories.map((c) => (
        <span
          class="inline-flex items-center px-2 py-0.5 text-[11px] font-medium tracking-wide text-[var(--color-sub)] border border-[var(--color-line)] rounded-sm bg-[var(--color-bg)]"
        >
          {c}
        </span>
      ))}
    </div>
  </div>
</section>
