---
/**
 * EduWatch JP brand mark — 双葉(cotyledon、非対称)
 *
 * モチーフ: 開き始めた双葉は「日々の新しい芽吹き = 日次の新ニュース」を象徴。
 * 左葉が先行して開き、右葉がまだ立ち上がりかけの非対称構図で「成長の瞬間」の
 * 動きを持たせる。姉妹サイト EduEvidence JP の「成熟した葉(左右対称)」と
 * 対になり、ストック型 vs フロー型の性格を視覚的に区別する。
 *
 * 色は currentColor を継承するので、呼び出し側で `color:` / Tailwind の
 * text- クラスを指定すれば反映される。
 *
 * viewBox は描画領域を詰めて、小さいサイズ(w-6, w-8)でもロゴの存在感を保つ。
 */
interface Props {
  class?: string;
}
const { class: className = "" } = Astro.props;
---
<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="10 20 100 96"
  class={className}
  aria-hidden="true"
  fill="currentColor"
>
  <!-- 右葉(大きめ・先行して上方向に広がる) -->
  <path d="M60 62 C76 28, 104 34, 108 64 C104 78, 82 82, 60 64 Z" />
  <line
    x1="66"
    y1="58"
    x2="98"
    y2="44"
    stroke="var(--color-bg, #faf9f5)"
    stroke-width="1.8"
    stroke-linecap="round"
  />
  <!-- 左葉(小さめ・やや遅れて開く、位置もやや下) -->
  <path d="M60 64 C46 48, 26 54, 22 74 C28 82, 44 80, 60 66 Z" />
  <line
    x1="54"
    y1="68"
    x2="30"
    y2="64"
    stroke="var(--color-bg, #faf9f5)"
    stroke-width="1.6"
    stroke-linecap="round"
  />
  <!-- 茎(微かに右に傾けて動きを出す) -->
  <line
    x1="60"
    y1="64"
    x2="63"
    y2="114"
    stroke="currentColor"
    stroke-width="3.5"
    stroke-linecap="round"
  />
</svg>
