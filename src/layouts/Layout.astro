---
import "../styles/global.css";
import Logo from "../components/Logo.astro";
interface Props {
  title?: string;
  description?: string;
  ogImagePath?: string;
}
const {
  title = "EduWatch JP — 教育ニュースを一次情報から追う",
  description = "文科省・国立教育政策研究所・OECD・EEF・主要新聞の教育面から、一次情報を日次で自動収集し、エビデンスの視点で整理する。EduEvidence JP 姉妹サイト。",
  ogImagePath,
} = Astro.props;
const siteUrl = "https://news.edu-evidence.org";
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).href;
const ogImage = ogImagePath ? `${siteUrl}${ogImagePath}` : `${siteUrl}/og-image.png`;

const escapeLd = (obj: object): string => JSON.stringify(obj).replace(/</g, "\\u003c");
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <script is:inline>
      (function () {
        try {
          const saved = localStorage.getItem("theme");
          const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
          const theme = saved === "dark" || saved === "light"
            ? saved
            : prefersDark
              ? "dark"
              : "light";
          document.documentElement.setAttribute("data-theme", theme);
        } catch {
          document.documentElement.setAttribute("data-theme", "light");
        }
      })();
    </script>
    <meta name="color-scheme" content="light dark" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content="EduWatch JP" />
    <meta property="og:locale" content="ja_JP" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <link rel="alternate" type="application/rss+xml" title="EduWatch JP — 週次ダイジェスト" href="/rss.xml" />

    <script
      type="application/ld+json"
      set:html={escapeLd({
        "@context": "https://schema.org",
        "@type": "WebSite",
        name: "EduWatch JP",
        url: siteUrl,
        description,
        inLanguage: "ja",
      })}
    />

    <!-- Cloudflare Web Analytics -->
    <script
      is:inline
      type="module"
      src="https://static.cloudflareinsights.com/beacon.min.js"
      data-cf-beacon='{"token": "cb05eab858a846e5863af9f3349d881c"}'></script>
  </head>
  <body class="bg-[var(--color-bg)] text-[var(--color-ink)]">
    <a href="#main-content" class="skip-link">本文へスキップ</a>
    <header class="site-header">
      <div class="mx-auto max-w-6xl px-4 sm:px-6 md:px-10 h-16 flex items-center justify-between gap-4">
        <a href="/" class="font-black text-lg sm:text-xl tracking-tight flex items-center gap-2 whitespace-nowrap">
          <span class="text-[var(--color-accent)] inline-flex shrink-0">
            <Logo class="w-8 h-8" />
          </span>
          EduWatch <span class="text-[var(--color-accent)]">JP</span>
        </a>
        <nav
          class="text-xs gap-4 lg:gap-6 text-[var(--color-sub)] hidden lg:flex items-center"
          aria-label="メインナビゲーション"
        >
          <a href="/categories/" class="link-underline">カテゴリ</a>
          <a href="/sources/" class="link-underline">媒体</a>
          <a href="/archive/" class="link-underline">アーカイブ</a>
          <a href="/digest/" class="link-underline">ダイジェスト</a>
          <a href="/about/" class="link-underline">サイトについて</a>
          <a
            href="https://edu-evidence.org"
            class="link-underline hover:text-[var(--color-ink)] transition"
            target="_blank"
            rel="noopener noreferrer"
          >
            エビデンスで探す ↗
          </a>
          <a href="/search/" class="hover:text-[var(--color-ink)] transition" aria-label="検索">
            <svg
              class="w-4 h-4 inline-block"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <circle cx="11" cy="11" r="8" />
              <path d="m21 21-4.3-4.3" />
            </svg>
          </a>
          <button
            id="theme-toggle"
            type="button"
            class="theme-toggle relative flex items-center justify-center w-8 h-8 text-[var(--color-sub)] hover:text-[var(--color-ink)] transition-colors"
            aria-label="ダークモードに切り替え"
            aria-pressed="false"
          >
            <svg class="theme-icon-moon w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
            </svg>
            <svg class="theme-icon-sun w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="12" cy="12" r="4" />
              <path d="M12 2v2" />
              <path d="M12 20v2" />
              <path d="m4.93 4.93 1.41 1.41" />
              <path d="m17.66 17.66 1.41 1.41" />
              <path d="M2 12h2" />
              <path d="M20 12h2" />
              <path d="m6.34 17.66-1.41 1.41" />
              <path d="m19.07 4.93-1.41 1.41" />
            </svg>
          </button>
        </nav>
        <button
          id="menu-toggle"
          type="button"
          class="lg:hidden relative flex flex-col justify-center items-center gap-1.5 w-10 h-10 -mr-2 shrink-0"
          aria-label="メニューを開く"
          aria-expanded="false"
          aria-controls="mobile-menu"
        >
          <span class="block w-6 h-[2px] bg-[var(--color-ink)] transition-transform duration-200 origin-center"></span>
          <span class="block w-6 h-[2px] bg-[var(--color-ink)] transition-opacity duration-200"></span>
          <span class="block w-6 h-[2px] bg-[var(--color-ink)] transition-transform duration-200 origin-center"></span>
        </button>
      </div>
    </header>

    <div
      id="mobile-menu"
      data-state="closed"
      class="mobile-menu lg:hidden"
      role="dialog"
      aria-modal="true"
      aria-label="モバイルナビゲーション"
      inert
    >
      <div class="mobile-menu-inner">
        <form
          class="mobile-menu-search"
          action="/search/"
          method="get"
          role="search"
        >
          <label for="mobile-menu-search-input" class="sr-only">検索</label>
          <svg
            class="mobile-menu-search-icon"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <circle cx="11" cy="11" r="8" />
            <path d="m21 21-4.3-4.3" />
          </svg>
          <input
            id="mobile-menu-search-input"
            type="search"
            name="q"
            placeholder="教育ニュースを検索..."
            autocomplete="off"
            enterkeyhint="search"
          />
        </form>

        <nav class="mobile-menu-nav" aria-label="サイトナビゲーション">
          <section class="mobile-menu-section">
            <h2 class="mobile-menu-section-title">Explore — 探す</h2>
            <ul>
              <li><a href="/categories/">カテゴリ</a></li>
              <li><a href="/sources/">媒体</a></li>
              <li><a href="/archive/">アーカイブ</a></li>
              <li><a href="/digest/">ダイジェスト</a></li>
            </ul>
          </section>

          <section class="mobile-menu-section">
            <h2 class="mobile-menu-section-title">About — サイトについて</h2>
            <ul>
              <li><a href="/about/">このサイトについて</a></li>
              <li><a href="/changelog/">更新履歴</a></li>
            </ul>
          </section>

          <section class="mobile-menu-section">
            <h2 class="mobile-menu-section-title">Sister Sites — 姉妹サイト</h2>
            <ul>
              <li><a href="https://edu-evidence.org">EduEvidence JP — 教育エビデンス</a></li>
              <li><a href="https://law.edu-evidence.org">EduLaw JP — 教育法令</a></li>
            </ul>
          </section>

          <section class="mobile-menu-section">
            <h2 class="mobile-menu-section-title">Display — 表示</h2>
            <button
              id="theme-toggle-mobile"
              type="button"
              class="theme-toggle mobile-menu-theme-toggle"
              aria-label="ダークモードに切り替え"
              aria-pressed="false"
            >
              <span class="mobile-menu-theme-toggle-icon" aria-hidden="true">
                <svg class="theme-icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
                </svg>
                <svg class="theme-icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="12" cy="12" r="4" />
                  <path d="M12 2v2" />
                  <path d="M12 20v2" />
                  <path d="m4.93 4.93 1.41 1.41" />
                  <path d="m17.66 17.66 1.41 1.41" />
                  <path d="M2 12h2" />
                  <path d="M20 12h2" />
                  <path d="m6.34 17.66-1.41 1.41" />
                  <path d="m19.07 4.93-1.41 1.41" />
                </svg>
              </span>
              <span class="mobile-menu-theme-toggle-label">ダークモードに切り替え</span>
            </button>
          </section>
        </nav>
      </div>
    </div>

    <button
      id="back-to-top"
      type="button"
      data-state="hidden"
      aria-label="ページ上部へ戻る"
      aria-hidden="true"
      tabindex="-1"
    >
      <svg
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="M12 19V5" />
        <path d="m5 12 7-7 7 7" />
      </svg>
    </button>

    <main id="main-content" tabindex="-1" class="mx-auto max-w-6xl px-4 sm:px-6 md:px-10 pb-24">
      <slot />
    </main>

    <footer class="border-t border-[var(--color-line)]">
      <div
        class="mx-auto max-w-6xl px-4 sm:px-6 md:px-10 py-8 md:py-12 grid md:grid-cols-3 gap-8 text-xs text-[var(--color-sub)] leading-relaxed"
      >
        <div class="space-y-4">
          <div class="font-black text-base text-[var(--color-ink)] flex items-center gap-2">
            <span class="text-[var(--color-accent)] inline-flex">
              <Logo class="w-6 h-6" />
            </span>
            EduWatch <span class="text-[var(--color-accent)]">JP</span>
          </div>
          <p>
            学校教員・教育関係者向けに、文科省・国研・教育専門紙の一次情報を日次で自動収集。
            週次ダイジェストで論点を整理します。
          </p>
          <div class="space-y-1.5 pt-2">
            <div class="font-mono uppercase tracking-widest text-[10px] text-[var(--color-ink)]">
              お問い合わせ
            </div>
            <ul class="space-y-1.5">
              <li>
                <a href="mailto:news@edu-evidence.org" class="link-underline">news@edu-evidence.org</a>
                <span class="text-[10px]">(運営)</span>
              </li>
              <li>
                <a href="mailto:takedown@edu-evidence.org" class="link-underline">takedown@edu-evidence.org</a>
                <span class="text-[10px]">(削除依頼)</span>
              </li>
            </ul>
          </div>
          <div class="space-y-1.5">
            <div class="font-mono uppercase tracking-widest text-[10px] text-[var(--color-ink)]">
              購読
            </div>
            <ul class="space-y-1.5">
              <li>
                <a href="/rss.xml" class="link-underline">RSS フィード(週次ダイジェスト)</a>
              </li>
            </ul>
          </div>
        </div>

        <div class="space-y-3">
          <div class="font-mono uppercase tracking-widest text-[var(--color-ink)]">探す</div>
          <ul class="space-y-1.5">
            <li><a href="/categories/" class="link-underline">カテゴリ</a></li>
            <li><a href="/sources/" class="link-underline">媒体</a></li>
            <li><a href="/archive/" class="link-underline">アーカイブ</a></li>
            <li><a href="/digest/" class="link-underline">ダイジェスト</a></li>
          </ul>
        </div>

        <div class="space-y-3">
          <div class="font-mono uppercase tracking-widest text-[var(--color-ink)]">サイト</div>
          <ul class="space-y-1.5">
            <li><a href="/about/" class="link-underline">このサイトについて</a></li>
            <li><a href="/changelog/" class="link-underline">更新履歴</a></li>
            <li>
              <a
                href="https://edu-evidence.org"
                class="link-underline"
                target="_blank"
                rel="noopener noreferrer"
              >EduEvidence JP ↗</a>
              <span class="text-[10px]">(姉妹サイト)</span>
            </li>
            <li>
              <a
                href="https://law.edu-evidence.org"
                class="link-underline"
                target="_blank"
                rel="noopener noreferrer"
              >EduLaw JP ↗</a>
              <span class="text-[10px]">(姉妹サイト)</span>
            </li>
          </ul>
        </div>
      </div>
      <div class="mx-auto max-w-6xl px-4 sm:px-6 md:px-10 pb-6 text-[10px] text-[var(--color-sub)]">
        © 2026 EduWatch JP. CC BY-SA 4.0.
      </div>
    </footer>

    <script is:inline>
      (function () {
        const buttons = [
          document.getElementById("theme-toggle"),
          document.getElementById("theme-toggle-mobile"),
        ].filter(Boolean);
        if (buttons.length === 0) return;
        const root = document.documentElement;
        const apply = (theme) => {
          root.setAttribute("data-theme", theme);
          const isDark = theme === "dark";
          const label = isDark ? "ライトモードに切り替え" : "ダークモードに切り替え";
          for (const btn of buttons) {
            btn.setAttribute("aria-pressed", String(isDark));
            btn.setAttribute("aria-label", label);
            const labelEl = btn.querySelector(".mobile-menu-theme-toggle-label");
            if (labelEl) labelEl.textContent = label;
          }
        };
        apply(root.getAttribute("data-theme") || "light");
        for (const btn of buttons) {
          btn.addEventListener("click", () => {
            const next = root.getAttribute("data-theme") === "dark" ? "light" : "dark";
            apply(next);
            try {
              localStorage.setItem("theme", next);
            } catch {
              // localStorage unavailable (private browsing) — apply for session only
            }
          });
        }
        const media = window.matchMedia("(prefers-color-scheme: dark)");
        media.addEventListener("change", (e) => {
          let saved = null;
          try {
            saved = localStorage.getItem("theme");
          } catch {
            // ignore
          }
          if (saved !== "dark" && saved !== "light") {
            apply(e.matches ? "dark" : "light");
          }
        });
      })();
    </script>

    <script is:inline>
      (function () {
        const toggle = document.getElementById("menu-toggle");
        const menu = document.getElementById("mobile-menu");
        if (!toggle || !menu) return;
        const bars = toggle.querySelectorAll("span");
        const searchInput = document.getElementById("mobile-menu-search-input");
        let isOpen = false;
        const setOpen = (open) => {
          isOpen = open;
          menu.dataset.state = open ? "open" : "closed";
          document.body.dataset.menu = open ? "open" : "closed";
          if (open) menu.removeAttribute("inert");
          else menu.setAttribute("inert", "");
          toggle.setAttribute("aria-expanded", String(open));
          toggle.setAttribute("aria-label", open ? "メニューを閉じる" : "メニューを開く");
          if (bars.length === 3) {
            bars[0].style.transform = open ? "translateY(8px) rotate(45deg)" : "";
            bars[1].style.opacity = open ? "0" : "";
            bars[2].style.transform = open ? "translateY(-8px) rotate(-45deg)" : "";
          }
          if (open && searchInput) {
            window.setTimeout(() => searchInput.focus({ preventScroll: true }), 50);
          } else if (!open) {
            toggle.focus({ preventScroll: true });
          }
        };
        toggle.addEventListener("click", () => setOpen(!isOpen));
        document.addEventListener("keydown", (e) => {
          if (e.key === "Escape" && isOpen) setOpen(false);
        });
        window.addEventListener("resize", () => {
          if (window.innerWidth >= 1024 && isOpen) setOpen(false);
        });
      })();
    </script>

    <script is:inline>
      (function () {
        const backToTop = document.getElementById("back-to-top");
        if (!backToTop) return;
        const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
        let ticking = false;
        const update = () => {
          ticking = false;
          const visible = window.scrollY > 600;
          const next = visible ? "visible" : "hidden";
          if (backToTop.dataset.state !== next) {
            backToTop.dataset.state = next;
            backToTop.setAttribute("aria-hidden", String(!visible));
            backToTop.setAttribute("tabindex", visible ? "0" : "-1");
          }
        };
        const onScroll = () => {
          if (ticking) return;
          ticking = true;
          window.requestAnimationFrame(update);
        };
        backToTop.addEventListener("click", () => {
          window.scrollTo({ top: 0, behavior: reduceMotion ? "auto" : "smooth" });
        });
        window.addEventListener("scroll", onScroll, { passive: true });
        window.addEventListener("resize", onScroll, { passive: true });
        update();
      })();
    </script>
  </body>
</html>
