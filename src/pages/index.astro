---
import Layout from "../layouts/Layout.astro";
import ArticleCard from "../components/ArticleCard.astro";
import SourcesIntro from "../components/SourcesIntro.astro";
import { getRecentArticles, groupByDate } from "../lib/articles.ts";

const RECENT_DAYS = 14;
const recent = getRecentArticles(RECENT_DAYS);
const groups = groupByDate(recent);

const dayFormatter = new Intl.DateTimeFormat("ja-JP", {
  month: "long",
  day: "numeric",
  weekday: "short",
  timeZone: "Asia/Tokyo",
});
function formatDayLabel(yyyyMmDd: string): string {
  const d = new Date(`${yyyyMmDd}T00:00:00+09:00`);
  return dayFormatter.format(d);
}
---

<Layout>
  <section class="pt-10 sm:pt-14 pb-8 border-b border-[var(--color-line)]">
    <p class="font-mono text-[10px] uppercase tracking-widest text-[var(--color-accent)]">
      Daily news from primary sources
    </p>
    <h1 class="mt-3 font-black text-3xl sm:text-4xl md:text-5xl leading-[1.15] tracking-tight">
      <span class="text-[var(--color-accent)]">一次情報</span>から、<br
        class="hidden sm:block"
      />教育の <span class="text-[var(--color-accent)]">今</span> を追う。
    </h1>
    <p class="mt-4 text-[var(--color-sub)] text-sm sm:text-base leading-loose max-w-2xl">
      文部科学省・国立教育政策研究所・中央教育審議会・教育専門紙・共同通信の教育記事を
      日次で自動収集。タイトル原文のまま、編集者の意見は加えず、公式 URL に直接リンクします。
    </p>
    <p class="mt-3 text-[var(--color-sub)] text-xs font-mono tracking-wide">
      直近 {RECENT_DAYS} 日 / {recent.length} 件
    </p>
  </section>

  <SourcesIntro />

  {
    groups.length === 0 ? (
      <p class="py-20 text-center text-[var(--color-sub)] text-sm">
        直近 {RECENT_DAYS} 日の記事はまだありません。
      </p>
    ) : (
      <div class="divide-y divide-[var(--color-line)]">
        {groups.map((group) => (
          <section class="py-8 sm:py-10">
            <h2 class="mb-4 sm:mb-6 font-mono text-xs uppercase tracking-widest text-[var(--color-sub)]">
              <time datetime={group.date}>{formatDayLabel(group.date)}</time>
              <span class="ml-3 text-[var(--color-sub)]">{group.articles.length} 件</span>
            </h2>
            <div>
              {group.articles.map((article) => (
                <ArticleCard article={article} />
              ))}
            </div>
          </section>
        ))}
      </div>
    )
  }
</Layout>
