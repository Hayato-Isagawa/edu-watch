---
import Layout from "../layouts/Layout.astro";
import ArticleCard from "../components/ArticleCard.astro";
import SourcesIntro from "../components/SourcesIntro.astro";
import { getRecentArticles, groupByDate, formatDayShort } from "../lib/articles.ts";

const RECENT_DAYS = 7;
const MAX_ITEMS = 50;
const recent = getRecentArticles(RECENT_DAYS);
const visible = recent.slice(0, MAX_ITEMS);
const overflow = Math.max(0, recent.length - visible.length);
const groups = groupByDate(visible);
---

<Layout>
  <section class="pt-10 sm:pt-14 pb-8 border-b border-[var(--color-line)]">
    <p class="font-mono text-[10px] uppercase tracking-widest text-[var(--color-accent)]">
      Daily news from primary sources
    </p>
    <h1 class="mt-3 font-black text-3xl sm:text-4xl md:text-5xl leading-[1.15] tracking-tight">
      <span class="text-[var(--color-accent)]">一次情報</span>から、<br
        class="hidden sm:block"
      />教育の <span class="text-[var(--color-accent)]">今</span> を追う。
    </h1>
    <p class="mt-4 text-[var(--color-sub)] text-sm sm:text-base leading-loose max-w-2xl">
      文部科学省・国立教育政策研究所・中央教育審議会・教育専門紙・共同通信の教育記事を
      日次で自動収集。タイトル原文のまま、編集者の意見は加えず、公式 URL に直接リンクします。
    </p>
    <p class="mt-3 text-[var(--color-sub)] text-xs font-mono tracking-wide">
      直近 {RECENT_DAYS} 日 / 表示 {visible.length} 件
      {recent.length > visible.length && (
        <span class="ml-1">(全 {recent.length} 件中)</span>
      )}
    </p>
  </section>

  <SourcesIntro />

  {
    groups.length === 0 ? (
      <p class="py-20 text-center text-[var(--color-sub)] text-sm">
        直近 {RECENT_DAYS} 日の記事はまだありません。
      </p>
    ) : (
      <div class="divide-y divide-[var(--color-line)]">
        {groups.map((group) => (
          <section class="py-8 sm:py-10">
            <h2 class="mb-4 sm:mb-6 font-mono text-xs uppercase tracking-widest text-[var(--color-sub)]">
              <time datetime={group.date}>{formatDayShort(group.date)}</time>
              <span class="ml-3 text-[var(--color-sub)]">{group.articles.length} 件</span>
            </h2>
            <div>
              {group.articles.map((article) => (
                <ArticleCard article={article} />
              ))}
            </div>
          </section>
        ))}
      </div>
    )
  }

  <section
    aria-labelledby="archive-link-heading"
    class="mt-4 sm:mt-6 p-5 sm:p-6 border border-[var(--color-line)] bg-[var(--color-card)] rounded-sm"
  >
    <h2
      id="archive-link-heading"
      class="font-mono text-[10px] uppercase tracking-widest text-[var(--color-sub)]"
    >
      これより古い記事
    </h2>
    {overflow > 0 && (
      <p class="mt-2 text-sm leading-relaxed text-[var(--color-sub)]">
        直近 {RECENT_DAYS} 日のうち、トップに表示しきれなかった {overflow} 件があります。
      </p>
    )}
    <ul class="mt-3 text-sm leading-relaxed space-y-1">
      <li>
        <a href="/archive/" class="link-underline text-[var(--color-ink)] font-bold">
          日付別アーカイブを見る →
        </a>
      </li>
      <li>
        <a href="/categories/" class="link-underline text-[var(--color-ink)] font-bold">
          カテゴリから探す →
        </a>
      </li>
    </ul>
    <p class="mt-2 text-[11px] leading-relaxed text-[var(--color-sub)]">
      媒体別ページは Sprint 3 後半で公開予定です。
    </p>
  </section>
</Layout>
