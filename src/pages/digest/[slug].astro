---
import { getCollection } from "astro:content";
import { marked } from "marked";
import DOMPurify from "isomorphic-dompurify";
import Layout from "../../layouts/Layout.astro";
import ArticleCard from "../../components/ArticleCard.astro";
import TopicBadge from "../../components/TopicBadge.astro";
import { getArticlesByIds, formatDayShort } from "../../lib/articles.ts";

export async function getStaticPaths() {
  const all = await getCollection("digests");
  const sorted = [...all].sort((a, b) =>
    b.data.publishedAt.localeCompare(a.data.publishedAt),
  );
  return sorted.map((entry, index) => ({
    params: { slug: entry.id },
    props: {
      entry,
      newer: index > 0 ? sorted[index - 1] : null,
      older: index < sorted.length - 1 ? sorted[index + 1] : null,
    },
  }));
}

const { entry, newer, older } = Astro.props;
const articleById = new Map(
  getArticlesByIds(entry.data.sections.flatMap((s) => s.articleIds)).map((a) => [a.id, a]),
);
const sectionsWithArticle = entry.data.sections.map((s) => ({
  heading: s.heading,
  commentHtml: DOMPurify.sanitize(marked.parse(s.comment) as string),
  articles: s.articleIds
    .map((id) => articleById.get(id))
    .filter((a): a is NonNullable<typeof a> => a !== undefined),
}));

const rangeFormatter = new Intl.DateTimeFormat("ja-JP", {
  year: "numeric",
  month: "long",
  day: "numeric",
  timeZone: "Asia/Tokyo",
});
function formatRange(from: string, to: string): string {
  const f = rangeFormatter.format(new Date(`${from}T00:00:00+09:00`));
  const t = rangeFormatter.format(new Date(`${to}T00:00:00+09:00`));
  return `${f} 〜 ${t}`;
}

const publishedFormatter = new Intl.DateTimeFormat("ja-JP", {
  year: "numeric",
  month: "long",
  day: "numeric",
  weekday: "short",
  timeZone: "Asia/Tokyo",
});
function formatPublished(iso: string): string {
  return publishedFormatter.format(new Date(iso));
}

function siteLabel(url: string): string | null {
  let host: string;
  try {
    host = new URL(url).hostname;
  } catch {
    return null;
  }
  if (host === "law.edu-evidence.org") return "EduLaw JP";
  if (host === "edu-evidence.org" || host === "www.edu-evidence.org")
    return "EduEvidence JP";
  return null;
}

function typeLabel(url: string): string | null {
  let parsed: URL;
  try {
    parsed = new URL(url);
  } catch {
    return null;
  }
  const { hostname, pathname } = parsed;
  if (hostname === "law.edu-evidence.org" && pathname.startsWith("/guides/"))
    return "法令ガイド";
  if (hostname === "edu-evidence.org" || hostname === "www.edu-evidence.org") {
    if (pathname.startsWith("/strategies/")) return "戦略";
    if (pathname.startsWith("/columns/")) return "コラム";
  }
  return null;
}
---

<Layout
  title={`${entry.data.title} — EduWatch JP 週次ダイジェスト`}
  description={entry.data.summary}
  ogImagePath={`/og/digest/${entry.id}.png`}
  longForm
>
  <article>
    <header class="pt-10 sm:pt-14 md:pt-20 lg:pt-28 pb-10 sm:pb-14 md:pb-20 border-b border-[var(--color-line)]">
      <p class="font-mono text-xs uppercase tracking-widest text-[var(--color-accent)]">
        Weekly digest
      </p>
      <h1 class="mt-5 font-black text-3xl sm:text-4xl md:text-5xl lg:text-6xl leading-[1.15] tracking-tight">
        {entry.data.title}
      </h1>
      <p class="mt-3 text-sm text-[var(--color-sub)] font-mono tracking-wide">
        <time datetime={entry.data.publishedAt}>公開: {formatPublished(entry.data.publishedAt)}</time>
        <span class="ml-3">
          <time datetime={entry.data.weekStart}>期間: {formatRange(entry.data.weekStart, entry.data.weekEnd)}</time>
        </span>
      </p>
      <p class="mt-6 text-[var(--color-sub)] text-sm sm:text-base leading-loose max-w-2xl">
        {entry.data.summary}
      </p>
      {
        entry.data.topics.length > 0 && (
          <div class="mt-6 flex flex-wrap gap-1.5">
            {entry.data.topics.map((t) => <TopicBadge topic={t} />)}
          </div>
        )
      }
      <p class="mt-6 text-[var(--color-sub)] text-sm leading-relaxed">
        <a href="/digest/" class="link-underline">← ダイジェスト一覧</a>
        <span class="ml-3"><a href="/" class="link-underline">トップ</a></span>
      </p>
    </header>

    {
      sectionsWithArticle.length > 0 && (
        <section class="py-2 border-b border-[var(--color-line)]">
          {sectionsWithArticle.map((s) => (
            <article class="py-8 sm:py-10 border-t border-[var(--color-line)] first:border-t-0">
              <h2 class="font-bold text-xl sm:text-2xl text-[var(--color-ink)]">
                {s.heading}
              </h2>
              {s.articles.length > 0 ? (
                <div class="mt-4 p-4 sm:p-5 border border-[var(--color-line)] bg-[var(--color-card)] rounded-sm">
                  <div class="font-mono text-[10px] uppercase tracking-widest text-[var(--color-sub)] mb-3">
                    {s.articles.length > 1 ? "Referenced articles" : "Referenced article"}
                  </div>
                  <div class="space-y-3">
                    {s.articles.map((a) => <ArticleCard article={a} />)}
                  </div>
                </div>
              ) : (
                <p class="mt-3 text-xs text-[var(--color-sub)]">
                  該当記事は現在表示できません(削除依頼などにより非掲載)。
                </p>
              )}
              <div class="prose-digest mt-4" set:html={s.commentHtml} />
            </article>
          ))}
        </section>
      )
    }

    {
      entry.data.relatedEvidenceUrls.length > 0 && (
        <section class="py-8 sm:py-10 border-b border-[var(--color-line)]">
          <h2 class="font-bold text-xl sm:text-2xl text-[var(--color-ink)]">
            関連リンク(姉妹サイト)
          </h2>
          <ul class="mt-4 space-y-3 text-sm leading-relaxed">
            {entry.data.relatedEvidenceUrls.map((link) => {
              const meta = [siteLabel(link.url), typeLabel(link.url)]
                .filter(Boolean)
                .join(" ・ ");
              return (
                <li>
                  <a
                    href={link.url}
                    class="link-underline font-medium"
                    target="_blank"
                    rel="noopener noreferrer"
                  >
                    {link.title} ↗
                  </a>
                  {meta && (
                    <div class="mt-0.5 text-xs text-[var(--color-sub)]">
                      {meta}
                    </div>
                  )}
                </li>
              );
            })}
          </ul>
        </section>
      )
    }

    <nav
      aria-label="ダイジェスト ナビゲーション"
      class="mt-2 mb-4 flex items-center justify-between gap-4 py-6"
    >
      {
        older ? (
          <a
            href={`/digest/${older.id}/`}
            rel="prev"
            class="link-underline text-sm text-[var(--color-ink)]"
          >
            ← 前週({formatDayShort(older.data.weekEnd)} まで)
          </a>
        ) : (
          <span class="text-sm text-[var(--color-sub)]">これより古いダイジェストなし</span>
        )
      }
      {
        newer ? (
          <a
            href={`/digest/${newer.id}/`}
            rel="next"
            class="link-underline text-sm text-[var(--color-ink)]"
          >
            次週({formatDayShort(newer.data.weekEnd)} まで) →
          </a>
        ) : (
          <span class="text-sm text-[var(--color-sub)]">最新のダイジェスト</span>
        )
      }
    </nav>
  </article>
</Layout>

<style is:global>
  .prose-digest {
    color: var(--color-ink);
    font-size: 17px;
    line-height: 1.8;
  }
  .prose-digest h2 {
    font-weight: 700;
    font-size: 1.25rem;
    line-height: 1.4;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    border-left: 3px solid var(--color-accent);
    padding-left: 0.75rem;
  }
  .prose-digest h2:first-child {
    margin-top: 0;
  }
  .prose-digest h3 {
    font-weight: 700;
    font-size: 1.05rem;
    line-height: 1.5;
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
  }
  .prose-digest p {
    margin: 0.85rem 0;
  }
  .prose-digest ul,
  .prose-digest ol {
    margin: 0.75rem 0 0.75rem 1.5rem;
  }
  .prose-digest ul {
    list-style: disc;
  }
  .prose-digest ol {
    list-style: decimal;
  }
  .prose-digest li + li {
    margin-top: 0.4rem;
  }
  .prose-digest a {
    color: var(--color-accent);
    text-decoration: none;
    background-image: linear-gradient(var(--color-accent), var(--color-accent));
    background-size: 0% 1px;
    background-position: left bottom;
    background-repeat: no-repeat;
    padding-bottom: 2px;
    transition:
      color 150ms ease-out,
      background-size 0.3s ease;
  }
  .prose-digest a:hover,
  .prose-digest a:focus,
  .prose-digest a:focus-visible {
    color: var(--color-accent);
    background-size: 100% 1px;
  }
  .prose-digest blockquote {
    margin: 1.25rem 0;
    padding: 0.5rem 1rem;
    border-left: 3px solid var(--color-line);
    color: var(--color-sub);
  }
  .prose-digest code {
    font-family: var(--font-mono);
    font-size: 0.85em;
    background: var(--color-card);
    padding: 0.1em 0.35em;
    border-radius: 3px;
  }
</style>
