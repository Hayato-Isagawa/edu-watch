node_modules
dist
.astro
.DS_Store
*.log
.env
.env.*
test-results
playwright-report
blob-report

# OG 画像生成のフォントは scripts/fonts/noto-sans-jp-bold.bin をリポジトリに同梱
# (ADR 0031、Google Fonts / jsDelivr への build-time 依存を排除)。
# その他の binary / 派生フォントは引き続き除外する。
scripts/fonts/*.woff2
scripts/fonts/*.otf
scripts/fonts/*.ttf
!scripts/fonts/noto-sans-jp-bold.bin

# Claude Code の生きたセッション状態(docs/context-management.md 参照)
.claude/state/
.claude/sessions/

# PoC / 実験用ディレクトリ(原則 git 管理外、PoC 採用時に必要部分のみ src/lib/ へ移管)。
# 例外: 採用済 ADR の運用機構として git 管理が必要なスクリプトは個別に許可する。
experiments/*
!experiments/poc-pdf-summary/
experiments/poc-pdf-summary/*
!experiments/poc-pdf-summary/fact-check-grep.mjs
!experiments/poc-pdf-summary/mapreduce-v3.mjs
!experiments/poc-pdf-summary/required-facts-gaiyouban.json
!experiments/poc-pdf-summary/chunk-ranges-gaiyouban.json
!experiments/poc-pdf-summary/chunk-ranges-v3.json
!experiments/poc-pdf-summary/observation-2026-05-12.md
!experiments/poc-pdf-summary/observation-2026-05-13.md
!experiments/poc-pdf-summary/observation-2026-05-13b.md
!experiments/poc-pdf-summary/observation-2026-05-17.md
!experiments/poc-pdf-summary/observation-2026-05-19.md
!experiments/poc-pdf-summary/observation-2026-05-24.md
!experiments/poc-pdf-summary/observation-2026-06-07.md
!experiments/poc-pdf-summary/verify-hypothesis-b.mjs
!experiments/poc-pdf-summary/extract-tsuuchi.mjs
!experiments/poc-pdf-summary/mapreduce-v4-tsuuchi.mjs
!experiments/poc-pdf-summary/chunk-ranges-v4-tsuuchi*.json
!experiments/poc-pdf-summary/required-facts-tsuuchi-*.json
!experiments/poc-pdf-summary/fact-check-grep-tsuuchi-*-raw-report.json
!experiments/poc-pdf-summary/summary-v4-tsuuchi-*-checked-raw*.md
