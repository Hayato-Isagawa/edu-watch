{
  "name": "edu-watch",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "prepare": "git config core.hooksPath .githooks 2>/dev/null || true",
    "dev": "astro dev",
    "build": "astro build && npx pagefind --site dist",
    "preview": "astro preview",
    "astro": "astro",
    "check": "astro check",
    "check:filter:resemom": "npx tsx scripts/check-resemom-filter.ts",
    "check:filter:kyodo": "npx tsx scripts/check-kyodo-filter.ts",
    "check:filter": "npm run check:filter:resemom && npm run check:filter:kyodo"
  },
  "dependencies": {
    "@astrojs/react": "^5.0.3",
    "@astrojs/sitemap": "^3.7.2",
    "@tailwindcss/vite": "^4.2.2",
    "@types/react": "^19.0.9",
    "@types/react-dom": "^19.0.3",
    "astro": "^6.1.8",
    "cheerio": "^1.2.0",
    "marked": "^18.0.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "rss-parser": "^3.13.0",
    "tailwindcss": "^4.2.2",
    "vite": "^7.3.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "pagefind": "^1.5.2",
    "typescript": "^5.9.3"
  }
}
