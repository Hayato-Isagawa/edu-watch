{
  "name": "edu-watch",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "prepare": "git config core.hooksPath .githooks 2>/dev/null || true",
    "dev": "astro dev",
    "build": "astro build && npx pagefind --site dist",
    "preview": "astro preview",
    "astro": "astro",
    "check": "astro check",
    "check:filter:resemom": "npx tsx scripts/check-resemom-filter.ts",
    "check:filter:kyodo": "npx tsx scripts/check-kyodo-filter.ts",
    "check:filter:kkn": "npx tsx scripts/check-kkn-filter.ts",
    "check:filter": "npm run check:filter:resemom && npm run check:filter:kyodo && npm run check:filter:kkn",
    "check:fetch:oecd": "npx tsx scripts/check-oecd-fetch.ts",
    "check:excluded-ids": "npx tsx scripts/check-excluded-ids.ts",
    "check:membership:nikkyo": "npx tsx scripts/check-nikkyo-membership.ts",
    "check:membership-updates": "npx tsx scripts/check-membership-updates.ts",
    "check:text": "textlint 'src/content/digests/**/*.md'",
    "check:text:fix": "textlint --fix 'src/content/digests/**/*.md'",
    "check:all": "npm run check && npm run check:text && npm run check:filter && npm run check:excluded-ids",
    "test:ai-summary": "node --test 'scripts/ai-summary/*.test.mjs'",
    "test:e2e": "npx playwright test",
    "test:e2e:ui": "npx playwright test --ui",
    "vrt": "npx playwright test --config playwright.vrt.config.ts",
    "og:default": "npx tsx scripts/generate-default-og.ts"
  },
  "dependencies": {
    "@astrojs/react": "^5.0.7",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.3",
    "@tailwindcss/vite": "^4.3.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.0.3",
    "astro": "^6.4.8",
    "cheerio": "^1.2.0",
    "isomorphic-dompurify": "^3.18.0",
    "marked": "^18.0.5",
    "pdf-parse": "^2.4.5",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "rss-parser": "^3.13.0",
    "satori": "^0.26.0",
    "sharp": "^0.35.2",
    "tailwindcss": "^4.2.2",
    "undici": "^8.5.0",
    "vite": "^7.3.6",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "pagefind": "^1.5.2",
    "textlint": "^15.7.0",
    "textlint-rule-no-mix-dearu-desumasu": "^6.0.4",
    "textlint-rule-preset-ja-spacing": "^3.0.2",
    "textlint-rule-preset-ja-technical-writing": "^12.0.2",
    "textlint-rule-prh": "^6.1.0",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "esbuild": "^0.28.1",
    "@babel/core": "^7.29.6",
    "js-yaml": "^4.2.0"
  }
}
